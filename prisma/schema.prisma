generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String    @id
  name                   String
  email                  String    @unique
  dni                    String
  phone                  String
  avatarUrl              String?   @map("avatar_url")
  verificationStatus     String    @default("pending") @map("verification_status")
  level                  String    @default("bronze")
  reputationScore        Float     @default(0) @map("reputation_score")
  preferredTransmission  String?   @map("preferred_transmission")
  preferredAccessibility String[]  @default([]) @map("preferred_accessibility")
  preferredMaxPriceDaily Int?      @map("preferred_max_price_daily")
  createdAt              DateTime  @default(now()) @map("created_at")
  vehicles               Vehicle[]

  @@map("users")
}

model Vehicle {
  id           String       @id @default(uuid())
  plate        String       @unique
  brand        String
  model        String
  year         Int
  passengers   Int
  trunkLiters  Float
  transmission Transmission
  isAccessible Boolean      @default(false)
  enabled      Boolean      @default(true)
  color        String
  mileage      Float
  basePrice    Float
  description  String?      @db.Text

  ownerId String
  owner   User    @relation(fields: [ownerId], references: [id])
  photos  Photo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vehicles")
}

model Photo {
  id        String  @id @default(uuid())
  url       String  @db.Text
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("photos")
}

enum Transmission {
  Manual
  Automatico
  Semiautomatico
}
