generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WalletMovementType {
  reservation_credit
  withdrawal_debit
}

enum WithdrawalStatus {
  processing
  processed
  failed
}

model User {
  id                    String     @id
  name                  String
  email                 String     @unique
  dni                   String
  phone                 String
  avatarUrl             String?    @map("avatar_url")
  verificationStatus    String     @default("pending") @map("verification_status")
  level                 String     @default("bronze")
  reputationScore       Float      @default(0) @map("reputation_score")
  balanceInCents        Int        @default(0) @map("balance_in_cents")
  preferredTransmission String?    @map("preferred_transmission")
  preferredAccessibility String[]  @default([]) @map("preferred_accessibility")
  preferredMaxPriceDaily Int?      @map("preferred_max_price_daily")
  autoAccept            Boolean    @default(false) @map("auto_accept")
  createdAt             DateTime   @default(now()) @map("created_at")
  phoneVerifiedAt       DateTime?  @map("phone_verified_at")
  favorites             Favorite[]
  vehicles              Vehicle[]
  reservationRuleSets   ReservationRuleSet[]
  reservations          Reservation[] @relation("conductor_reservations")
  paymentMethods        UserPaymentMethod[]
  messages              Message[]
  bankAccounts          BankAccount[]
  walletMovements       WalletMovement[]
  withdrawals           Withdrawal[]
  identityVerification  IdentityVerification?
  driverLicenseVerification DriverLicenseVerification?
  pushSubscriptions     PushSubscription[]

  @@map("users")
}

model IdentityVerification {
  id               String                        @id @default(uuid())
  userId           String                        @unique @map("user_id")
  status           IdentityVerificationStatus    @default(not_started)
  providerName     String?                       @map("provider_name")
  providerRequestId String?                      @unique @map("provider_request_id")
  rejectionReason  String?                       @map("rejection_reason") @db.VarChar(280)
  submittedAt      DateTime?                     @map("submitted_at") @db.Timestamptz(6)
  reviewAfterAt    DateTime?                     @map("review_after_at") @db.Timestamptz(6)
  reviewedAt       DateTime?                     @map("reviewed_at") @db.Timestamptz(6)
  verifiedAt       DateTime?                     @map("verified_at") @db.Timestamptz(6)
  documents        Json                          @default("{}")
  createdAt        DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             User                          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, reviewAfterAt])
  @@map("identity_verifications")
}

model DriverLicenseVerification {
  id                String                     @id @default(uuid())
  userId            String                     @unique @map("user_id")
  status            IdentityVerificationStatus  @default(not_started)
  providerName      String?                    @map("provider_name")
  providerRequestId String?                    @unique @map("provider_request_id")
  rejectionReason   String?                    @map("rejection_reason") @db.VarChar(280)
  submittedAt       DateTime?                  @map("submitted_at") @db.Timestamptz(6)
  reviewAfterAt     DateTime?                  @map("review_after_at") @db.Timestamptz(6)
  reviewedAt        DateTime?                  @map("reviewed_at") @db.Timestamptz(6)
  verifiedAt        DateTime?                  @map("verified_at") @db.Timestamptz(6)
  documents         Json                       @default("{}")
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, reviewAfterAt])
  @@map("driver_license_verifications")
}

model Favorite {
  id          String   @id @default(uuid())
  conductorId String   @map("conductor_id")
  vehicleId   String   @map("vehicle_id")
  createdAt   DateTime @default(now()) @map("created_at")

  conductor   User     @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@unique([conductorId, vehicleId])
  @@map("favorites")
}

model Vehicle {
  id           String       @id @default(uuid())
  plate        String       @unique
  brand        String
  model        String
  year         Int
  passengers   Int
  trunkLiters  Float
  transmission Transmission
  isAccessible Boolean      @default(false)
  enabled      Boolean      @default(true)
  color        String
  mileage      Float
  basePriceCents Int    @map("base_price_cents")
  description  String?      @db.Text
  province     String
  city         String
  address      String?
  latitude     Float?
  longitude    Float?
  locationApproximate Boolean @default(false) @map("location_approximate")
  availableFrom String      @map("available_from")
  autoAccept   Boolean?     @map("auto_accept")

  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id])
  reservationRuleSetId String? @map("reservation_rule_set_id")
  // Set "compartido" (vehicleId IS NULL en RuleSet) — el vehículo apunta al set.
  reservationRuleSet ReservationRuleSet? @relation("SharedRuleSet", fields: [reservationRuleSetId], references: [id], onDelete: SetNull)
  // Set "privado" (RuleSet.vehicleId apunta al vehículo). Cascade en DB.
  privateRuleSet     ReservationRuleSet? @relation("PrivateRuleSet")
  photos       Photo[]
  characteristics VehicleCharacteristic[]
  reservations    Reservation[]
  promotion       PromotionActive?
  vehicleDocument VehicleDocumentVerification?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([latitude, longitude])
  @@map("vehicles")
}

model BankAccount {
  id         String   @id @default(uuid())
  ownerId    String   @map("owner_id")
  provider   String
  alias      String
  cbu        String
  isActive   Boolean  @default(true) @map("is_active")
  isVerified Boolean  @default(true) @map("is_verified")
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  withdrawals Withdrawal[]
  walletMovements WalletMovement[]

  @@index([ownerId, deletedAt])
  @@map("bank_accounts")
}

model Withdrawal {
  id                    String            @id @default(uuid())
  userId                String            @map("user_id")
  bankAccountId         String            @map("bank_account_id")
  bankAccountAlias      String            @map("bank_account_alias")
  bankAccountMaskedCbu  String            @map("bank_account_masked_cbu")
  bankAccountProvider   String            @map("bank_account_provider")
  amountCents           Int               @map("amount_cents")
  currency              String            @default("ARS")
  providerName          String            @map("provider_name")
  providerTransactionId String            @unique @map("provider_transaction_id")
  providerStatus        WithdrawalStatus   @map("provider_status")
  status                WithdrawalStatus   @default(processed)
  providerMetadata      Json              @default("{}") @map("provider_metadata")
  balanceAfterCents      Int               @map("balance_after_cents")
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt           DateTime?         @map("processed_at") @db.Timestamptz(6)
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount           BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  walletMovement        WalletMovement?

  @@index([userId, createdAt])
  @@map("withdrawals")
}

model WalletMovement {
  id                    String            @id @default(uuid())
  userId                String            @map("user_id")
  type                  WalletMovementType
  amountCents           Int               @map("amount_cents")
  currency              String            @default("ARS")
  reservationId         String?           @unique @map("reservation_id")
  withdrawalId          String?           @unique @map("withdrawal_id")
  providerTransactionId String?           @map("provider_transaction_id")
  bankAccountId         String?           @map("bank_account_id")
  bankAccountAlias      String?           @map("bank_account_alias")
  bankAccountMaskedCbu  String?           @map("bank_account_masked_cbu")
  providerStatus        WithdrawalStatus?  @map("provider_status")
  balanceAfterCents      Int               @map("balance_after_cents")
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation           Reservation?      @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  withdrawal            Withdrawal?       @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  bankAccount           BankAccount?      @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([withdrawalId])
  @@map("wallet_movements")
}

model ReservationRuleSet {
  id                  String             @id @default(uuid())
  ownerId             String             @map("owner_id")
  // `vehicleId` define el scope del set: NULL = compartido (puede aplicarse a
  // varios vehículos del owner); UUID = privado de ese vehículo (UNIQUE +
  // ON DELETE CASCADE). Inmutable post-creación (validado en la service).
  vehicleId           String?            @unique @map("vehicle_id")
  name                String
  description         String?            @db.Text
  cancellationPolicy  CancellationPolicy @map("cancellation_policy")
  // Porcentaje de seña entero entre 10 y 50, o NULL para "sin seña".
  // Reemplaza al enum `Deposit` (US-49).
  depositPercentage   Int?               @map("deposit_percentage")
  maxKilometrageType  MaxKilometrageType @map("max_kilometrage_type")
  maxKilometrageValue Int?               @map("max_kilometrage_value")
  minRentalDays       Int?               @map("min_rental_days")
  maxRentalDays       Int?               @map("max_rental_days")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  owner               User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // Vehículo "privado" — solo cuando vehicleId != null. Cascade: si se borra
  // el vehículo, el set privado se borra con él (US-49 AC #8).
  privateVehicle      Vehicle?           @relation("PrivateRuleSet", fields: [vehicleId], references: [id], onDelete: Cascade)
  // Vehículos que apuntan a este set como `reservation_rule_set_id`
  // (solo aplica si es compartido).
  vehicles            Vehicle[]          @relation("SharedRuleSet")

  @@map("reservation_rule_sets")
}

model Reservation {
  id                  String             @id @default(uuid())
  vehicleId           String             @map("vehicle_id")
  vehicle             Vehicle            @relation(fields: [vehicleId], references: [id])
  conductorId         String             @map("conductor_id")
  conductor           User               @relation("conductor_reservations", fields: [conductorId], references: [id])
  rentadorId          String             @map("rentador_id")
  status              ReservationStatus  @default(pending_payment)
  startAt             DateTime           @map("start_at") @db.Timestamptz(6)
  endAt               DateTime           @map("end_at") @db.Timestamptz(6)
  holdExpiresAt       DateTime?          @map("hold_expires_at") @db.Timestamptz(6)
  totalCents          Int                @map("total_cents")
  currency            String             @default("ARS")
  paymentMethod       PaymentMethod?     @map("payment_method")
  walletProvider      String?            @map("wallet_provider")
  contractAcceptedAt  DateTime?          @map("contract_accepted_at") @db.Timestamptz(6)
  paidAt              DateTime?          @map("paid_at") @db.Timestamptz(6)
  voucherToken        String?            @map("voucher_token") @db.Uuid
  returnQrToken       String?            @unique @map("return_qr_token") @db.Uuid
  startedAt           DateTime?          @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime?          @map("completed_at") @db.Timestamptz(6)
  rejectionReason     String?            @map("rejection_reason") @db.VarChar(280)
  transferExpiresAt   DateTime?          @map("transfer_expires_at") @db.Timestamptz(6)
  transferCode        String?            @map("transfer_code")
  transferAlias       String?            @map("transfer_alias")
  parentReservationId String?            @map("parent_reservation_id")
  parentReservation   Reservation?       @relation("ReservationExtensions", fields: [parentReservationId], references: [id])
  extensions          Reservation[]      @relation("ReservationExtensions")
  // Snapshot inmutable de reglas + precio al confirmar la reserva (US-49).
  // Si el rentador cambia el set o el precio post-confirmación, la reserva
  // mantiene los valores con que se firmó el contrato.
  depositPercentageSnapshot     Int?    @map("deposit_percentage_snapshot")
  basePriceCentsSnapshot        Int     @default(0) @map("base_price_cents_snapshot")
  cancellationPolicySnapshot    String  @default("FLEXIBLE") @map("cancellation_policy_snapshot")
  maxKilometrageTypeSnapshot    String  @default("UNLIMITED") @map("max_kilometrage_type_snapshot")
  maxKilometrageValueSnapshot   Int?    @map("max_kilometrage_value_snapshot")
  minRentalDaysSnapshot         Int     @default(1) @map("min_rental_days_snapshot")
  maxRentalDaysSnapshot         Int?    @map("max_rental_days_snapshot")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  messages            Message[]
  walletMovement      WalletMovement?

  @@index([vehicleId, status])
  @@index([conductorId])
  @@index([rentadorId, status])
  @@index([status, createdAt])
  @@index([parentReservationId])
  @@map("reservations")
}

model Message {
  id            String      @id @default(uuid())
  reservationId String      @map("reservation_id")
  senderId      String      @map("sender_id")
  body          String      @db.Text
  sentAt        DateTime    @default(now()) @map("sent_at") @db.Timestamptz(6)

  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  sender        User        @relation(fields: [senderId], references: [id])

  @@index([reservationId, sentAt, id])
  @@map("messages")
}

model Photo {
  id        String  @id @default(uuid())
  url       String  @db.Text
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model VehicleCharacteristic {
  id             String         @id
  vehicleId      String         @map("vehicle_id")
  characteristic Characteristic
  createdAt      DateTime       @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, characteristic])
  @@map("vehicle_characteristics")
}

model PromotionActive {
  vehicleId          String    @id @map("vehicle_id")
  durationDays       Int       @map("duration_days")
  totalCents         Int       @map("total_cents")
  status             String    @map("status")
  paymentMethod      String    @map("payment_method")
  paidAt             DateTime? @map("paid_at")
  transactionId      String?   @map("transaction_id")
  transferCode       String?   @map("transfer_code")
  transferAlias      String?   @map("transfer_alias")
  transferExpiresAt  DateTime? @map("transfer_expires_at")
  startDate          DateTime  @map("start_date")
  createdAt          DateTime  @default(now()) @map("created_at")

  vehicle            Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("promotions_active")
}

model PromotionLengthInDays {
  days             Int         @id
  valueInCents     Int         @map("value_in_cents")
  @@map("promotion_length_in_days")
}

model VehicleDocumentVerification {
  id               String                             @id @default(uuid())
  vehicleId        String                             @unique @map("vehicle_id")
  rentadorId       String                             @map("rentador_id")
  status           VehicleDocumentVerificationStatus   @default(pending)
  documents        Json                               @default("{}")
  rejectionReason  String?                            @map("rejection_reason") @db.VarChar(280)
  submittedAt      DateTime                           @map("submitted_at") @db.Timestamptz(6)
  reviewedAt       DateTime?                          @map("reviewed_at") @db.Timestamptz(6)
  verifiedAt       DateTime?                          @map("verified_at") @db.Timestamptz(6)
  createdAt        DateTime                           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                           @updatedAt @map("updated_at") @db.Timestamptz(6)

  vehicle          Vehicle                            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([status, submittedAt])
  @@map("vehicle_document_verifications")
}

enum Transmission {
  Manual
  Automatico
  Semiautomatico
}

enum VehicleDocumentVerificationStatus {
  pending
  verified
  rejected
}

enum IdentityVerificationStatus {
  not_started
  pending
  verified
  rejected
}

enum DriverLicenseVerificationStatus {
  not_started
  pending
  verified
  rejected
}

enum ReservationStatus {
  pending_approval
  pending_payment
  confirmed
  in_progress
  completed
  cancelled
  rejected
  expired
}

enum PaymentMethod {
  credit_card
  debit_card
  bank_transfer
  digital_wallet
  card // Adding card type to align with contracts
}

model UserPaymentMethod {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  type      PaymentMethod
  details   Json
  isDefault Boolean       @default(false) @map("is_default")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_payment_methods")
}

model PushSubscription {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  endpoint       String   @unique
  auth           String
  p256dh         String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

enum Characteristic {
  GPS
  BABY_SEAT
  SUNROOF
  PET_FRIENDLY
  WIFI
  USB_CHARGER
  AUX_CABLE
  BLUETOOTH
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

enum MaxKilometrageType {
  UNLIMITED
  LIMITED
}
