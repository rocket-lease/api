generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String     @id
  name                  String
  email                 String     @unique
  dni                   String
  phone                 String
  avatarUrl             String?    @map("avatar_url")
  verificationStatus    String     @default("pending") @map("verification_status")
  level                 String     @default("bronze")
  reputationScore       Float      @default(0) @map("reputation_score")
  balanceInCents        Int        @default(0) @map("balance_in_cents")
  preferredTransmission String?    @map("preferred_transmission")
  preferredAccessibility String[]  @default([]) @map("preferred_accessibility")
  preferredMaxPriceDaily Int?      @map("preferred_max_price_daily")
  autoAccept            Boolean    @default(false) @map("auto_accept")
  createdAt             DateTime   @default(now()) @map("created_at")
  phoneVerifiedAt       DateTime?  @map("phone_verified_at")
  favorites             Favorite[]
  vehicles              Vehicle[]
  reservationRuleSets   ReservationRuleSet[]
  reservations          Reservation[] @relation("conductor_reservations")

  @@map("users")
}

model Favorite {
  id          String   @id @default(uuid())
  conductorId String   @map("conductor_id")
  vehicleId   String   @map("vehicle_id")
  createdAt   DateTime @default(now()) @map("created_at")

  conductor   User     @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@unique([conductorId, vehicleId])
  @@map("favorites")
}

model Vehicle {
  id           String       @id @default(uuid())
  plate        String       @unique
  brand        String
  model        String
  year         Int
  passengers   Int
  trunkLiters  Float
  transmission Transmission
  isAccessible Boolean      @default(false)
  enabled      Boolean      @default(true)
  color        String
  mileage      Float
  basePriceCents Int    @map("base_price_cents")
  description  String?      @db.Text
  province     String
  city         String
  address      String?
  latitude     Float?
  longitude    Float?
  locationApproximate Boolean @default(false) @map("location_approximate")
  availableFrom String      @map("available_from")
  autoAccept   Boolean?     @map("auto_accept")

  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id])
  reservationRuleSetId String? @map("reservation_rule_set_id")
  // Set "compartido" (vehicleId IS NULL en RuleSet) — el vehículo apunta al set.
  reservationRuleSet ReservationRuleSet? @relation("SharedRuleSet", fields: [reservationRuleSetId], references: [id], onDelete: SetNull)
  // Set "privado" (RuleSet.vehicleId apunta al vehículo). Cascade en DB.
  privateRuleSet     ReservationRuleSet? @relation("PrivateRuleSet")
  photos       Photo[]
  characteristics VehicleCharacteristic[]
  reservations    Reservation[]
  promotion       PromotionActive?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([latitude, longitude])
  @@map("vehicles")
}

model ReservationRuleSet {
  id                  String             @id @default(uuid())
  ownerId             String             @map("owner_id")
  // `vehicleId` define el scope del set: NULL = compartido (puede aplicarse a
  // varios vehículos del owner); UUID = privado de ese vehículo (UNIQUE +
  // ON DELETE CASCADE). Inmutable post-creación (validado en la service).
  vehicleId           String?            @unique @map("vehicle_id")
  name                String
  description         String?            @db.Text
  cancellationPolicy  CancellationPolicy @map("cancellation_policy")
  // Porcentaje de seña entero entre 10 y 50, o NULL para "sin seña".
  // Reemplaza al enum `Deposit` (US-49).
  depositPercentage   Int?               @map("deposit_percentage")
  maxKilometrageType  MaxKilometrageType @map("max_kilometrage_type")
  maxKilometrageValue Int?               @map("max_kilometrage_value")
  minRentalDays       Int?               @map("min_rental_days")
  maxRentalDays       Int?               @map("max_rental_days")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  owner               User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // Vehículo "privado" — solo cuando vehicleId != null. Cascade: si se borra
  // el vehículo, el set privado se borra con él (US-49 AC #8).
  privateVehicle      Vehicle?           @relation("PrivateRuleSet", fields: [vehicleId], references: [id], onDelete: Cascade)
  // Vehículos que apuntan a este set como `reservation_rule_set_id`
  // (solo aplica si es compartido).
  vehicles            Vehicle[]          @relation("SharedRuleSet")

  @@map("reservation_rule_sets")
}

model Reservation {
  id                  String             @id @default(uuid())
  vehicleId           String             @map("vehicle_id")
  vehicle             Vehicle            @relation(fields: [vehicleId], references: [id])
  conductorId         String             @map("conductor_id")
  conductor           User               @relation("conductor_reservations", fields: [conductorId], references: [id])
  rentadorId          String             @map("rentador_id")
  status              ReservationStatus  @default(pending_payment)
  startAt             DateTime           @map("start_at") @db.Timestamptz(6)
  endAt               DateTime           @map("end_at") @db.Timestamptz(6)
  holdExpiresAt       DateTime?          @map("hold_expires_at") @db.Timestamptz(6)
  totalCents          Int                @map("total_cents")
  currency            String             @default("ARS")
  paymentMethod       PaymentMethod?     @map("payment_method")
  walletProvider      String?            @map("wallet_provider")
  contractAcceptedAt  DateTime?          @map("contract_accepted_at") @db.Timestamptz(6)
  paidAt              DateTime?          @map("paid_at") @db.Timestamptz(6)
  voucherToken        String?            @map("voucher_token") @db.Uuid
  returnQrToken       String?            @unique @map("return_qr_token") @db.Uuid
  startedAt           DateTime?          @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime?          @map("completed_at") @db.Timestamptz(6)
  rejectionReason     String?            @map("rejection_reason") @db.VarChar(280)
  transferExpiresAt   DateTime?          @map("transfer_expires_at") @db.Timestamptz(6)
  transferCode        String?            @map("transfer_code")
  transferAlias       String?            @map("transfer_alias")
  // Snapshot inmutable de reglas + precio al confirmar la reserva (US-49).
  // Si el rentador cambia el set o el precio post-confirmación, la reserva
  // mantiene los valores con que se firmó el contrato.
  depositPercentageSnapshot     Int?    @map("deposit_percentage_snapshot")
  basePriceCentsSnapshot        Int     @default(0) @map("base_price_cents_snapshot")
  cancellationPolicySnapshot    String  @default("FLEXIBLE") @map("cancellation_policy_snapshot")
  maxKilometrageTypeSnapshot    String  @default("UNLIMITED") @map("max_kilometrage_type_snapshot")
  maxKilometrageValueSnapshot   Int?    @map("max_kilometrage_value_snapshot")
  minRentalDaysSnapshot         Int     @default(1) @map("min_rental_days_snapshot")
  maxRentalDaysSnapshot         Int?    @map("max_rental_days_snapshot")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([vehicleId, status])
  @@index([conductorId])
  @@index([rentadorId, status])
  @@index([status, createdAt])
  @@map("reservations")
}

model Photo {
  id        String  @id @default(uuid())
  url       String  @db.Text
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model VehicleCharacteristic {
  id             String         @id
  vehicleId      String         @map("vehicle_id")
  characteristic Characteristic
  createdAt      DateTime       @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, characteristic])
  @@map("vehicle_characteristics")
}

model PromotionActive {
  vehicleId          String    @id @map("vehicle_id")
  durationDays       Int       @map("duration_days")
  totalCents         Int       @map("total_cents")
  status             String    @map("status")
  paymentMethod      String    @map("payment_method")
  paidAt             DateTime? @map("paid_at")
  transactionId      String?   @map("transaction_id")
  transferCode       String?   @map("transfer_code")
  transferAlias      String?   @map("transfer_alias")
  transferExpiresAt  DateTime? @map("transfer_expires_at")
  startDate          DateTime  @map("start_date")
  createdAt          DateTime  @default(now()) @map("created_at")

  vehicle            Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("promotions_active")
}

model PromotionLengthInDays {
  days             Int         @id
  valueInCents     Int         @map("value_in_cents")
  @@map("promotion_length_in_days")
}

enum Transmission {
  Manual
  Automatico
  Semiautomatico
}

enum ReservationStatus {
  pending_approval
  pending_payment
  confirmed
  in_progress
  completed
  cancelled
  rejected
  expired
}

enum PaymentMethod {
  credit_card
  debit_card
  bank_transfer
  digital_wallet
}

enum Characteristic {
  GPS
  BABY_SEAT
  SUNROOF
  PET_FRIENDLY
  WIFI
  USB_CHARGER
  AUX_CABLE
  BLUETOOTH
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

enum MaxKilometrageType {
  UNLIMITED
  LIMITED
}
