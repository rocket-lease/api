{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-test.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^@rocket-lease/contracts$": "<rootDir>/../../contracts/src/index.ts",
    "^@rocket-lease/contracts/(.*)$": "<rootDir>/../../contracts/src/$1"
  }
}
